{
  "name": "webgemini-cli",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/cli.ts",
    "start": "bun run src/cli.ts",
    "build": "bun build ./src/cli.ts --outfile ./dist/webgemini.exe --compile -e playwright -e playwright-core -e chromium-bidi -e electron",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@lightpanda/browser": "^1.2.0",
    "commander": "^14.0.3",
    "playwright": "^1.58.2"
  }
}
